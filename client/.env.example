# Sao chép thành `client/.env`
# Server chỉ phục vụ API dưới /api/* — dùng một trong hai (client tự thêm /api nếu bạn chỉ ghi host:port):
#   API_BASE_URL=http://127.0.0.1:8000/api
#   API_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000/api

# Mặc định giao diện khi chưa có file jobhub_data/ui_theme.json (light hoặc dark)
UI_THEME=light
USE_MOCK_DATA=true
MOCK_USER_ROLE=candidate