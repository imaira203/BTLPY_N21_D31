  <property name="styleSheet">
   <string notr="true">
QMainWindow { background-color: #F8FAFC; }
#sidebar { background-color: #0F172A; border: none; }
#brandTitle { color: #FFFFFF; font-size: 24px; font-weight: 800; padding: 28px 24px 30px 24px; }
#brandSubtitle { color: #64748B; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 0px 24px 30px 24px; }
QPushButton.navBtn { background-color: transparent; color: #94A3B8; border: none; border-radius: 8px; padding: 12px 20px; text-align: left; font-size: 14px; font-weight: 500; margin: 4px 15px; }
QPushButton.navBtn:hover { background-color: #1E293B; color: #F1F5F9; }
QPushButton.navBtn:checked { background-color: #6366F1; color: #FFFFFF; font-weight: 700; }
#btnLogout { color: #FB7185; margin-bottom: 25px; }
#btnLogout:hover { background-color: #451a1a; }
#topBar { background-color: #FFFFFF; border-bottom: 1px solid #E2E8F0; min-height: 70px; max-height: 70px; }
#pageTitle { font-size: 22px; font-weight: 700; color: #0F172A; }
#pageSubTitle { font-size: 13px; color: #64748B; }
#hrName { font-size: 14px; font-weight: 600; color: #1E293B; }
#hrRole { font-size: 12px; color: #64748B; }
#hrAvatar { background-color: #6366F1; color: white; font-weight: 800; border-radius: 20px; }
QFrame#chartFrame, QFrame.cardFrame { background-color: #FFFFFF; border: 1px solid #E2E8F0; border-radius: 20px; }
QLineEdit, QPlainTextEdit { background-color: #FFFFFF; border: 1px solid #E2E8F0; border-radius: 8px; padding: 10px; font-size: 14px; }
QLineEdit:focus, QPlainTextEdit:focus { border: 1px solid #6366F1; }
QPushButton#btnSubmitJob { background-color: #6366F1; color: white; border-radius: 8px; padding: 12px 24px; font-weight: 700; }
QPushButton#btnSubmitJob:hover { background-color: #4F46E5; }
QPushButton#btnSaveDraft { background-color: #F1F5F9; color: #475569; border-radius: 8px; padding: 12px 24px; font-weight: 600; }
