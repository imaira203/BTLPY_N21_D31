 <class>UserDashboard</class>
 <widget class="QMainWindow" name="UserDashboard">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1280</width><height>850</height></rect>
  </property>
  <property name="windowTitle"><string>JobHub - Người tìm việc</string></property>
  <property name="styleSheet">
   <string notr="true">
/* MODERN PREMIUM STYLE */
QMainWindow { background-color: #F8FAFC; font-family: 'Inter', 'Segoe UI', sans-serif; }
#sidebar { background-color: #0F172A; border: none; }
#brandLabel { color: #FFFFFF; font-size: 24px; font-weight: 800; padding: 28px 24px 5px 24px; }
#adminPanelLabel { color: #64748B; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 0px 24px 30px 24px; }

QPushButton.navBtn {
    background-color: transparent;
    color: #94A3B8;
    border: none;
    border-radius: 8px;
    padding: 12px 20px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 4px 15px;
}
QPushButton.navBtn:hover { background-color: #1E293B; color: #F1F5F9; }
QPushButton.navBtn:checked { background-color: #6366F1; color: #FFFFFF; font-weight: 700; }

#btnLogout { color: #FB7185; margin-bottom: 25px; }

#topBar { background-color: #FFFFFF; border-bottom: 1px solid #E2E8F0; min-height: 70px; max-height: 70px; }
#pageTitle { font-size: 22px; font-weight: 700; color: #0F172A; }
#pageSubTitle { font-size: 13px; color: #64748B; }

/* Profile Page Specific Styles */
#profileCard { background-color: white; border-radius: 24px; border: 1px solid #E2E8F0; }

#avatarCircle { 
    background-color: #6366F1; 
    color: white; 
    font-size: 26px; 
    font-weight: 800; 
    border-radius: 40px; 
}

.sectionHeader { 
    color: #0F172A; 
    font-size: 12px; 
    font-weight: 800; 
    text-transform: uppercase; 
    letter-spacing: 1.2px; 
    margin-bottom: 15px; 
}

.infoItem { color: #1E293B; font-size: 14px; font-weight: 500; padding: 5px 0; }

.skillPill { 
    background-color: #EEF2FF; 
    color: #6366F1; 
    border-radius: 12px; 
    padding: 8px 16px; 
    font-weight: 700; 
    font-size: 12px; 
}

#aboutMeText { color: #475569; font-size: 14px; line-height: 1.6; }

/* CV Management Zone */
#cvZone { 
    background-color: #F8FAFC; 
    border: 1px dashed #CBD5E1; 
    border-radius: 16px; 
    padding: 24px; 
}

QPushButton.cvActionBtn {
    background-color: white;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    color: #475569;
    font-size: 13px;
    font-weight: 600;
    padding: 8px 16px;
}
QPushButton.cvActionBtn:hover { background-color: #F1F5F9; border-color: #CBD5E1; }

QPushButton#btnReplaceCV {
    background-color: #6366F1;
    color: white;
    border: none;
}
QPushButton#btnReplaceCV:hover { background-color: #4F46E5; }

/* Shared Utilities */
QLineEdit#searchBar {
    background-color: #F8FAFC;
    border: 1px solid #E2E8F0;
    border-radius: 10px;
    padding: 8px 15px;
}
   </string>
