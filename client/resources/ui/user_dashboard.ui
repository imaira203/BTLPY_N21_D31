 <class>UserDashboard</class>
 <widget class="QMainWindow" name="UserDashboard">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1600</width><height>900</height></rect>
  </property>
  <property name="windowTitle"><string>JobHub - Người tìm việc</string></property>
  <property name="styleSheet">
   <string notr="true">
/* ─────────────────────────────────────────────────────────────────── */
/* JOBHUB PREMIUM MODERN STYLE - PROFESSIONAL & SPACIOUS              */
/* ────────────────────────────��────────────────────────────────────── */

QMainWindow { 
    background-color: #F8FAFC; 
    font-family: 'Segoe UI', 'Inter', -apple-system, sans-serif;
}

/* ── SIDEBAR STYLING ────────────────────────────────────────────── */
#sidebar { 
    background-color: #0F172A; 
    border: none;
    padding: 0px;
}

#brandLabel { 
    color: #FFFFFF; 
    font-size: 26px; 
    font-weight: 900;
    padding: 32px 28px 8px 28px;
    letter-spacing: -0.5px;
}

#adminPanelLabel { 
    color: #64748B; 
    font-size: 11px; 
    font-weight: 700; 
    text-transform: uppercase; 
    letter-spacing: 1.5px; 
    padding: 0px 28px 40px 28px;
}

QPushButton.navBtn {
    background-color: transparent;
    color: #94A3B8;
    border: none;
    border-radius: 10px;
    padding: 14px 22px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 6px 16px;
    transition: all 0.2s ease;
}

QPushButton.navBtn:hover { 
    background-color: #1E293B; 
    color: #E2E8F0;
    padding-left: 26px;
}

QPushButton.navBtn:checked { 
    background-color: #6366F1; 
    color: #FFFFFF; 
    font-weight: 700;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
}

#btnLogout { 
    color: #FB7185; 
    margin-bottom: 32px;
    margin-top: auto;
}

#btnLogout:hover {
    background-color: rgba(251, 113, 133, 0.1) !important;
}

/* ── TOP BAR STYLING ────────────────────────────────────────────── */
#topBar { 
    background-color: #FFFFFF; 
    border-bottom: 1px solid #E2E8F0;
    min-height: 75px;
    max-height: 75px;
    padding: 0px;
}

#pageTitle { 
    font-size: 24px; 
    font-weight: 800; 
    color: #0F172A;
    letter-spacing: -0.5px;
}

#pageSubTitle { 
    font-size: 13px; 
    color: #64748B;
    font-weight: 500;
}

/* ── SEARCH BAR ────────────────────────────────────────────────── */
QLineEdit#searchBar {
    background-color: #F1F5F9;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 10px 18px;
    font-size: 13px;
    color: #1E293B;
    min-width: 300px;
}

QLineEdit#searchBar:focus {
    border: 2px solid #6366F1;
    background-color: #FFFFFF;
}

QLineEdit#searchBar::placeholder {
    color: #94A3B8;
}

/* ── COMBOBOX / DROPDOWN STYLING ────────────────────────────────── */
QComboBox {
    background-color: #FFFFFF;
    border: 1.5px solid #E2E8F0;
    border-radius: 10px;
    padding: 8px 14px;
    font-size: 13px;
    color: #1E293B;
    font-weight: 500;
    min-width: 140px;
    height: 38px;
}

QComboBox:hover {
    border: 1.5px solid #CBD5E1;
    background-color: #FFFFFF;
}

QComboBox:focus {
    border: 2px solid #6366F1;
    background-color: #FFFFFF;
    box-shadow: 0 0 8px rgba(99, 102, 241, 0.2);
}

QComboBox::drop-down {
    border: none;
    width: 32px;
    background-color: transparent;
}

QComboBox::down-arrow {
    image: none;
    background-color: transparent;
    width: 0px;
}

/* Custom arrow styling */
QComboBox::down-arrow:on {
    top: 1px;
}

QComboBox::indicator:checked {
    background-color: transparent;
}

/* ── COMBOBOX DROPDOWN POPUP ────────────────────────────────────── */
QComboBox QAbstractItemView {
    background-color: #FFFFFF;
    border: 1.5px solid #E2E8F0;
    border-radius: 10px;
    outline: none;
    selection-background-color: #EEF2FF;
    color: #1E293B;
}

QComboBox QAbstractItemView::item {
    padding: 10px 14px;
    border: none;
    min-height: 36px;
}

QComboBox QAbstractItemView::item:hover {
    background-color: #F1F5F9;
    color: #6366F1;
}

QComboBox QAbstractItemView::item:selected {
    background-color: #EEF2FF;
    color: #6366F1;
    font-weight: 600;
}

/* ── STATS CARDS CONTAINER ─────────────────────────────────────── */
#statsContainer {
    background-color: transparent;
    border: none;
}

#statCard {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 16px;
    padding: 0px;
}

#statCard:hover {
    border-color: #CBD5E1;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
}

#statIcon {
    background-color: transparent;
    border-radius: 14px;
    font-size: 32px;
    font-weight: 700;
    min-width: 64px;
    min-height: 64px;
    max-width: 64px;
    max-height: 64px;
}

#statIcon.green {
    background-color: #D1FAE5;
}

#statIcon.blue {
    background-color: #DBEAFE;
}

#statIcon.red {
    background-color: #FEE2E2;
}

#statNumber {
    font-size: 36px;
    font-weight: 900;
    color: #0F172A;
    letter-spacing: -0.5px;
}

#statLabel {
    font-size: 13px;
    color: #64748B;
    font-weight: 500;
}

/* ── PROFILE PAGE STYLING ──────────────────────────────────────── */
#profileCard { 
    background-color: #FFFFFF; 
    border-radius: 20px; 
    border: 1px solid #E2E8F0;
    padding: 0px;
}

#avatarCircle { 
    background-color: #6366F1; 
    color: white; 
    font-size: 32px; 
    font-weight: 900; 
    border-radius: 50px;
    min-width: 100px;
    min-height: 100px;
    max-width: 100px;
    max-height: 100px;
}

.sectionHeader { 
    color: #0F172A; 
    font-size: 12px; 
    font-weight: 800; 
    text-transform: uppercase; 
    letter-spacing: 1.3px;
    margin-bottom: 16px;
}

.infoItem { 
    color: #1E293B; 
    font-size: 14px; 
    font-weight: 500; 
    padding: 6px 0px;
}

.skillPill { 
    background-color: #EEF2FF; 
    color: #6366F1; 
    border-radius: 14px; 
    padding: 10px 18px; 
    font-weight: 700; 
    font-size: 12px;
    border: 1px solid #DDD6FE;
}

#aboutMeText { 
    color: #475569; 
    font-size: 14px; 
    line-height: 1.8;
    font-weight: 500;
}

/* ── CV MANAGEMENT ZONE ────────────────────────────────────────── */
#cvZone { 
    background-color: #F8FAFC; 
    border: 2px dashed #CBD5E1; 
    border-radius: 14px; 
    padding: 28px;
}

QPushButton.cvActionBtn {
    background-color: #FFFFFF;
    border: 1.5px solid #E2E8F0;
    border-radius: 10px;
    color: #475569;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 20px;
    transition: all 0.2s ease;
}

QPushButton.cvActionBtn:hover { 
    background-color: #F1F5F9; 
    border-color: #CBD5E1;
    color: #1E293B;
}

QPushButton#btnReplaceCV {
    background-color: #6366F1;
    color: #FFFFFF;
    border: none;
}

QPushButton#btnReplaceCV:hover { 
    background-color: #4F46E5;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
}

/* ── EDIT PROFILE BUTTON ────────────────────────────────────────── */
QPushButton#btnEditProfile {
    background-color: #6366F1;
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 13px;
    padding: 12px 24px;
    transition: all 0.2s ease;
}

QPushButton#btnEditProfile:hover {
    background-color: #4F46E5;
    box-shadow: 0 6px 16px rgba(99, 102, 241, 0.35);
}

/* ── JOB CARDS & GRID ──────────────────────────────────────────── */
#scrollContent { 
    background-color: transparent;
}

/* ── TABLE WIDGET ──────────────────────────────────────────────── */
QTableWidget {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    gridline-color: #F1F5F9;
}

QTableWidget::item {
    padding: 12px 8px;
    color: #1E293B;
}

QTableWidget::item:selected {
    background-color: #EEF2FF;
    color: #6366F1;
}

QHeaderView::section {
    background-color: #F8FAFC;
    color: #0F172A;
    padding: 12px 8px;
    border: none;
    border-bottom: 1px solid #E2E8F0;
    font-weight: 700;
    font-size: 12px;
}

/* ── SCROLL AREA ────────────────────────────────────────────────── */
QScrollArea {
    border: none;
    background-color: transparent;
}

QScrollBar:vertical {
    background-color: transparent;
    width: 10px;
}

QScrollBar::handle:vertical {
    background-color: #CBD5E1;
    border-radius: 5px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background-color: #94A3B8;
}

QScrollBar::up-arrow:vertical, QScrollBar::down-arrow:vertical {
    border: none;
    background: none;
}

   </string>
