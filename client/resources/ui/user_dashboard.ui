<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>UserDashboard</class>
 <widget class="QMainWindow" name="UserDashboard">
  <property name="geometry">
   <rect><x>0</x><y>0</y><width>1280</width><height>850</height></rect>
  </property>
  <property name="windowTitle"><string>JobHub - Người tìm việc</string></property>
  <property name="styleSheet">
   <string notr="true">
/* MODERN PREMIUM STYLE */
QMainWindow { background-color: #F8FAFC; font-family: 'Inter', 'Segoe UI', sans-serif; }
#sidebar { background-color: #0F172A; border: none; }
#brandLabel { color: #FFFFFF; font-size: 24px; font-weight: 800; padding: 28px 24px 5px 24px; }
#adminPanelLabel { color: #64748B; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 0px 24px 30px 24px; }

QPushButton.navBtn {
    background-color: transparent;
    color: #94A3B8;
    border: none;
    border-radius: 8px;
    padding: 12px 20px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 4px 15px;
}
QPushButton.navBtn:hover { background-color: #1E293B; color: #F1F5F9; }
QPushButton.navBtn:checked { background-color: #6366F1; color: #FFFFFF; font-weight: 700; }

#btnLogout { color: #FB7185; margin-bottom: 25px; }

#topBar { background-color: #FFFFFF; border-bottom: 1px solid #E2E8F0; min-height: 70px; max-height: 70px; }
#pageTitle { font-size: 22px; font-weight: 700; color: #0F172A; }
#pageSubTitle { font-size: 13px; color: #64748B; }

/* UTILITY CARDS */
.card { 
    background-color: white; 
    border-radius: 20px; 
    border: 1px solid #E2E8F0; 
}

/* Profile Specific */
#bannerFrame {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #6366F1, stop:1 #A855F7);
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
    min-height: 140px;
}

#avatarContainer {
    background-color: white;
    border-radius: 50px;
    padding: 4px;
}

#avatarCircle { 
    background-color: #6366F1; 
    color: white; 
    font-size: 32px; 
    font-weight: 800; 
    border-radius: 46px; 
}

.sectionHeader { 
    color: #0F172A; 
    font-size: 13px; 
    font-weight: 800; 
    text-transform: uppercase; 
    letter-spacing: 1.5px; 
}

.infoLabel { color: #64748B; font-size: 12px; font-weight: 600; text-transform: uppercase; }
.infoValue { color: #1E293B; font-size: 15px; font-weight: 500; }

.skillPill { 
    background-color: #EEF2FF; 
    color: #6366F1; 
    border-radius: 10px; 
    padding: 6px 14px; 
    font-weight: 700; 
    font-size: 12px; 
}

#cvZone { 
    background-color: #F8FAFC; 
    border: 2px dashed #E2E8F0; 
    border-radius: 16px; 
}

QPushButton.primaryBtn {
    background-color: #6366F1;
    color: white;
    border-radius: 10px;
    font-weight: 700;
    font-size: 14px;
    padding: 10px 20px;
}
QPushButton.primaryBtn:hover { background-color: #4F46E5; }

QPushButton.secondaryBtn {
    background-color: #F1F5F9;
    color: #475569;
    border-radius: 10px;
    font-weight: 600;
    font-size: 13px;
    padding: 8px 16px;
}
QPushButton.secondaryBtn:hover { background-color: #E2E8F0; }
    
   </string>
