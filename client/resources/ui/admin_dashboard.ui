   <string notr="true">
/* Admin Dashboard Main Shell Styles */
QMainWindow { background-color: #F8FAFC; }

/* Sidebar Styling */
#sidebar {
    background-color: #0F172A;
    border: none;
}
#brandLabel {
    color: #FFFFFF;
    font-size: 24px;
    font-weight: 800;
    padding: 28px 24px 5px 24px;
}
#adminPanelLabel {
    color: #64748B;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0px 24px 30px 24px;
}

QPushButton.navBtn {
    background-color: transparent;
    color: #94A3B8;
    border: none;
    border-radius: 8px;
    padding: 12px 20px;
    text-align: left;
    font-size: 14px;
    font-weight: 500;
    margin: 4px 15px;
}
QPushButton.navBtn:hover {
    background-color: #1E293B;
    color: #F1F5F9;
}
QPushButton.navBtn:checked {
    background-color: #6366F1;
    color: #FFFFFF;
    font-weight: 700;
}

#logoutButton {
    color: #FB7185;
    margin-bottom: 25px;
}
#logoutButton:hover {
    background-color: #451a1a;
}

/* Header/TopBar */
#topBar {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E2E8F0;
    min-height: 70px;
    max-height: 70px;
}
#pageTitle {
    font-size: 22px;
    font-weight: 700;
    color: #0F172A;
}
#pageSubTitle {
    font-size: 13px;
    color: #64748B;
}

#adminName { font-size: 14px; font-weight: 600; color: #1E293B; }
#adminRole { font-size: 12px; color: #64748B; }
#adminAvatar {
    background-color: #6366F1;
    color: white;
    font-weight: 800;
    border-radius: 20px;
}
