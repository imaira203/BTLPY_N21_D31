               <widget class="QTabWidget" name="tabWidget">
                <property name="styleSheet">
                 <string notr="true">/* Nút Đăng nhập & Đăng ký (Màu xanh chuẩn) */
#btnLogin, #btnRegister {
    background-color: #2563eb;
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 12px;
    font-size: 15px;
    font-weight: 700;
    min-height: 20px;
}

#btnLogin:hover, #btnRegister:hover {
    background-color: #1d4ed8;
}

/* Tab buttons */
#tabWidget QTabBar::tab {
    background: #f3f4f6;
    color: #6b7280;
    padding: 10px 25px;
    border-radius: 8px;
    margin-right: 8px;
    font-weight: 600;
}
#tabWidget QTabBar::tab:selected {
    background: #ffffff;
    color: #2563eb;
    border: 1px solid #e5e7eb;
}
</string>
